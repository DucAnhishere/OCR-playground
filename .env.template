# =========================================================================
#                   OCR PLAYGROUND ENVIRONMENT TEMPLATE
# =========================================================================
# Sao chép file này thành .env và điền các giá trị thích hợp trước khi chạy dự án.
# Copy this file to .env and fill in the appropriate values before running.

# -------------------------------------------------------------------------
# 1. Supabase Configuration (Cấu hình lưu trữ ảnh Supabase)
# -------------------------------------------------------------------------
# Cần thiết để lưu trữ và lấy URL công khai cho ảnh gốc và ảnh đã qua xử lý.
# Required for persisting images and returning public URLs.
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-or-service-role-key
SUPABASE_BUCKET=ocr-images

# -------------------------------------------------------------------------
# 2. Microservice Routing (Cấu hình định tuyến Microservice)
# -------------------------------------------------------------------------
# Sử dụng giá trị mặc định cho Docker Compose (tên container).
# Thay thế bằng localhost hoặc IP khác nếu chạy trực tiếp bên ngoài Docker.
# Defaults are optimized for Docker Compose. Change if running services on host.
IMAGE_PROCESSOR_URL=http://image-processor:8004
PYTORCH_SERVICE_URL=http://ocr-pytorch:8002
PADDLE_SERVICE_URL=http://ocr-paddle:8003

# -------------------------------------------------------------------------
# 3. OCR Engine Configuration (Cấu hình công cụ OCR)
# -------------------------------------------------------------------------
# Đường dẫn file trọng số của VietOCR bên trong container PyTorch.
# VietOCR model weights file path inside the PyTorch container.
VIETOCR_WEIGHTS_PATH=/root/.vietocr/vgg_transformer.pth
VIETOCR_CONFIG_NAME=vgg_transformer
